# Database
POSTGRES_USER=app_user
POSTGRES_PASSWORD=<generate-a-strong-password>
POSTGRES_DB=project_management
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Docker image (update with your actual GHCR image path)
DOCKER_IMAGE=ghcr.io/<your-github-username>/x_project:latest

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<generate-a-strong-secret-key>

# AWS S3
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=<your-s3-bucket-name>
# S3_ENDPOINT_URL is not set in production — uses real AWS
