aws_region      = "us-east-1"
project_name    = "project-management"
instance_type   = "t3.small"
s3_bucket_name  = "project-management-files"
ssh_public_key  = "ssh-rsa AAAA... your-key-here"
allowed_ssh_cidrs = ["0.0.0.0/0"]  # Restrict to your IP in production: ["1.2.3.4/32"]

# Lambda (optional — defaults work for most cases)
# lambda_memory_size        = 512
# lambda_timeout            = 30
# lambda_log_retention_days = 14
# pillow_layer_zip_path     = "../lambdas/layers/pillow.zip"
